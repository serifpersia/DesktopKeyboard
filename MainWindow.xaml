<Window x:Class="DesktopKeyboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopKeyboard" Height="360" Width="850"
        Topmost="True" Focusable="False" ShowActivated="False" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Visibility="Hidden" ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="Button" x:Key="KeyStyle">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,3"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#353535"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#111111"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="TopIconStyle" BasedOn="{StaticResource KeyStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>
    </Window.Resources>
    <Viewbox Stretch="Uniform">
        <Border Width="850" Height="360" Background="#111111" CornerRadius="8" BorderBrush="#333" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,10,0">
                        <Button Content="📐 Size" Style="{StaticResource TopIconStyle}" Width="70" Click="SizeButton_Click"/>
                        <Button Content="—" Style="{StaticResource TopIconStyle}" Width="40" FontSize="20" Click="MinimizeButton_Click"/>
                        <Button Content="✕" Style="{StaticResource TopIconStyle}" Width="40" FontSize="20" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1" Margin="10,5,10,15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <UniformGrid Grid.Row="0" Rows="1" Columns="11">
                        <Button Style="{StaticResource KeyStyle}" Content="1" Tag="1" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="2" Tag="2" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="3" Tag="3" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="4" Tag="4" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="5" Tag="5" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="6" Tag="6" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="7" Tag="7" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="8" Tag="8" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="9" Tag="9" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="0" Tag="0" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="Del" Tag="BACK" Click="Key_Click" FontSize="18"/>
                    </UniformGrid>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource KeyStyle}" Content="q" Tag="Q" Click="Key_Click"/>
                        <Button Grid.Column="1" Style="{StaticResource KeyStyle}" Content="w" Tag="W" Click="Key_Click"/>
                        <Button Grid.Column="2" Style="{StaticResource KeyStyle}" Content="e" Tag="E" Click="Key_Click"/>
                        <Button Grid.Column="3" Style="{StaticResource KeyStyle}" Content="r" Tag="R" Click="Key_Click"/>
                        <Button Grid.Column="4" Style="{StaticResource KeyStyle}" Content="t" Tag="T" Click="Key_Click"/>
                        <Button Grid.Column="5" Style="{StaticResource KeyStyle}" Content="y" Tag="Y" Click="Key_Click"/>
                        <Button Grid.Column="6" Style="{StaticResource KeyStyle}" Content="u" Tag="U" Click="Key_Click"/>
                        <Button Grid.Column="7" Style="{StaticResource KeyStyle}" Content="i" Tag="I" Click="Key_Click"/>
                        <Button Grid.Column="8" Style="{StaticResource KeyStyle}" Content="o" Tag="O" Click="Key_Click"/>
                        <Button Grid.Column="9" Style="{StaticResource KeyStyle}" Content="p" Tag="P" Click="Key_Click"/>
                        <Button Grid.Column="10" Style="{StaticResource KeyStyle}" Content="⌫" Tag="BACK" Click="Key_Click"/>
                    </Grid>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.5*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="1" Style="{StaticResource KeyStyle}" Content="a" Tag="A" Click="Key_Click"/>
                        <Button Grid.Column="2" Style="{StaticResource KeyStyle}" Content="s" Tag="S" Click="Key_Click"/>
                        <Button Grid.Column="3" Style="{StaticResource KeyStyle}" Content="d" Tag="D" Click="Key_Click"/>
                        <Button Grid.Column="4" Style="{StaticResource KeyStyle}" Content="f" Tag="F" Click="Key_Click"/>
                        <Button Grid.Column="5" Style="{StaticResource KeyStyle}" Content="g" Tag="G" Click="Key_Click"/>
                        <Button Grid.Column="6" Style="{StaticResource KeyStyle}" Content="h" Tag="H" Click="Key_Click"/>
                        <Button Grid.Column="7" Style="{StaticResource KeyStyle}" Content="j" Tag="J" Click="Key_Click"/>
                        <Button Grid.Column="8" Style="{StaticResource KeyStyle}" Content="k" Tag="K" Click="Key_Click"/>
                        <Button Grid.Column="9" Style="{StaticResource KeyStyle}" Content="l" Tag="L" Click="Key_Click"/>
                        <Button Grid.Column="10" Style="{StaticResource KeyStyle}" Content="↵" Tag="ENTER" Click="Key_Click"/>
                    </Grid>
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnShift" Grid.Column="0" Style="{StaticResource KeyStyle}" Content="⇧" Tag="TOGGLE_SHIFT" Click="Key_Click" FontSize="26"/>
                        <Button Grid.Column="1" Style="{StaticResource KeyStyle}" Content="z" Tag="Z" Click="Key_Click"/>
                        <Button Grid.Column="2" Style="{StaticResource KeyStyle}" Content="x" Tag="X" Click="Key_Click"/>
                        <Button Grid.Column="3" Style="{StaticResource KeyStyle}" Content="c" Tag="C" Click="Key_Click"/>
                        <Button Grid.Column="4" Style="{StaticResource KeyStyle}" Content="v" Tag="V" Click="Key_Click"/>
                        <Button Grid.Column="5" Style="{StaticResource KeyStyle}" Content="b" Tag="B" Click="Key_Click"/>
                        <Button Grid.Column="6" Style="{StaticResource KeyStyle}" Content="n" Tag="N" Click="Key_Click"/>
                        <Button Grid.Column="7" Style="{StaticResource KeyStyle}" Content="m" Tag="M" Click="Key_Click"/>
                        <Button Grid.Column="8" Style="{StaticResource KeyStyle}" Content="," Tag="COMMA" Click="Key_Click"/>
                        <Button Grid.Column="9" Style="{StaticResource KeyStyle}" Content="." Tag="PERIOD" Click="Key_Click"/>
                        <Button Grid.Column="10" Style="{StaticResource KeyStyle}" Content="/" Tag="SLASH" Click="Key_Click"/>
                        <Button Grid.Column="11" Style="{StaticResource KeyStyle}" Content="↑" Tag="UP" Click="Key_Click" FontSize="26"/>
                    </Grid>
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="9*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnCtrl" Grid.Column="0" Style="{StaticResource KeyStyle}" Content="Ctrl" Tag="TOGGLE_CTRL" Click="Key_Click" FontSize="18"/>
                        <Button Grid.Column="1" Style="{StaticResource KeyStyle}" Content="Space" Tag="SPACE" Click="Key_Click" FontSize="18"/>
                        <Button Grid.Column="2" Style="{StaticResource KeyStyle}" Content="←" Tag="LEFT" Click="Key_Click" FontSize="22"/>
                        <Button Grid.Column="3" Style="{StaticResource KeyStyle}" Content="↓" Tag="DOWN" Click="Key_Click" FontSize="22"/>
                        <Button Grid.Column="4" Style="{StaticResource KeyStyle}" Content="→" Tag="RIGHT" Click="Key_Click" FontSize="22"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Viewbox>
</Window>